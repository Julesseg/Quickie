<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!--
	  Base Info.plist for the app target. GENERATE_INFOPLIST_FILE is still YES, so
	  Xcode merges the generated keys and every INFOPLIST_KEY_* build setting on
	  top of this file at build time (the supported "generated plist + custom keys"
	  pattern). This file carries only what the generator can't express: the
	  quickie:// custom URL scheme (issue #45, #46; ADR 0007): the inbound route the
	  Sync Shortcut returns names on (import) and the run callbacks a triggered
	  Shortcut Action comes back on (shortcut-result / -error / -cancel) all ride it.
	-->
	<!--
	  CloudKit sync (ADR 0023, issue #107): the remote-notification background
	  mode lets the system deliver the silent pushes CloudKit sends when another
	  device changes the private database, so SwiftData can import in the
	  background instead of only on next foreground.
	-->
	<!--
	  The Pending-query Live Activity (issue #152; ADR 0031): while the
	  30-second window is open, the unfinished query is glanceable on the Lock
	  Screen / Dynamic Island. The app requests/ends the activity; the widget
	  extension renders it.
	-->
	<key>NSSupportsLiveActivities</key>
	<true/>
	<key>UIBackgroundModes</key>
	<array>
		<string>remote-notification</string>
	</array>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>CFBundleURLName</key>
			<string>com.julesseguin.quickie.urlscheme</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>quickie</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
